    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = { ...raw.body, ...raw };\n// Constantes de normalización (Anexo A)\nconst CART_VALUE_MAX  = 200000; // ARS — precio máx. catálogo × 1,1\nconst ABANDONMENT_MAX = 5;      // umbral de abandono recurrente\n// Pesos (Anexo A)\nconst W_VALUE      = 0.50;\nconst W_ABANDONMENT = 0.30;\nconst W_STAGE      = 0.20;\n// Valores discretos por etapa (Anexo A)\nconst STAGE_SCORES = {\n  browsing:          0.25,\n  cart:              0.50,\n  checkout_started:  0.75,\n  payment_page:      1.00,\n};\nconst cartValue        = parseFloat(body.cart_value) || 0;\nconst abandonmentCount = parseInt(body.previous_abandonment_count) || parseInt(raw.body?.previous_abandonment_count) || 0;\nconst cartStage        = body.cart_stage || raw.body?.cart_stage || 'cart';\nconst pValor    = Math.min(cartValue        / CART_VALUE_MAX,  1);\nconst pAbandono = Math.min(abandonmentCount / ABANDONMENT_MAX, 1);\nconst pEtapa    = STAGE_SCORES[cartStage] ?? 0.25;\nconst puntuacion = (pValor * W_VALUE + pAbandono * W_ABANDONMENT + pEtapa * W_STAGE) * 100;\nlet prioridad;\nif (puntuacion >= 70) {\n  prioridad = 'ALTA';\n} else if (puntuacion >= 40) {\n  prioridad = 'MEDIA';\n} else {\n  prioridad = 'BAJA';\n}\nconst items        = body.items || body.cart?.items || raw.body?.cart?.items || [];\nconst itemsResumen = items.map(i => `${i.name} (x${i.quantity}) - $${i.price}`).join(', ');\nreturn [{\n  json: {\n    customer_id:                body.customer_id   || 'sin-id',\n    name:                       body.name          || 'Cliente',\n    email:                      body.email         || '',\n    telegram_chat_id:           body.telegram_chat_id || '',\n    cart_value:                 cartValue,\n    cart_stage:                 cartStage,\n    previous_abandonment_count: abandonmentCount,\n    checkout_url:               body.checkout_url || body.cart?.checkout_url || 'https://technova.com.ar/checkout',\n    items_resumen:              itemsResumen      || 'productos seleccionados',\n    puntuacion:                 Math.round(puntuacion * 10) / 10,\n    prioridad:                  prioridad,\n    timestamp_evento:           body.timestamp    || new Date().toISOString(),\n    timestamp_procesado:        new Date().toISOString()\n  }\n}];"
      },
